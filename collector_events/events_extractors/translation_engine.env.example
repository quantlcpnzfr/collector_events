# Copy to translation_engine.env for local overrides.

# MQ input/output
TRANSLATION_INPUT_TOPIC="intel.events.#"
TRANSLATION_OUTPUT_PREFIX=intel.translated
TRANSLATION_HEALTH_TOPIC=intel.translation.health

# Ray
TRANSLATION_RAY_ACTORS=2
TRANSLATION_RAY_ACTOR_CONCURRENCY=4
TRANSLATION_RAY_INFLIGHT_PER_ACTOR=32
TRANSLATION_RAY_NAMESPACE=osint_translation

# GlotLID language detection
GLOTLID_MODEL_PATH=C:\Projects\forex_system\services\collector_events\.models\translation\glotlid\model.bin
GLOTLID_REPO_ID=cis-lmu/glotlid
GLOTLID_AUTO_DOWNLOAD=false
TRANSLATION_MIN_DETECTION_CONFIDENCE=0.35

# Translation provider:
#   none    = detect language only
#   nllb    = facebook/nllb-200-distilled-600M or TRANSLATION_MODEL_PATH
#   opus_mt = Helsinki-NLP/opus-mt-mul-en or TRANSLATION_MODEL_PATH
TRANSLATION_PROVIDER=none
TRANSLATION_MODEL_PATH=
TRANSLATION_TARGET_LANGUAGE=eng_Latn
TRANSLATION_MAX_TEXT_CHARS=4000
TRANSLATION_DEVICE=auto
TRANSLATION_NLLB_NUM_BEAMS=2
TRANSLATION_NLLB_MAX_NEW_TOKENS=512

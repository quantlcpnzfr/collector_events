# ======================================================================
# 2. MESSAGE QUEUE — RabbitMQ / Redis  (MQConfig)
# ======================================================================
# Transporte de mensagens entre microserviços distribuídos.
# Exchange: "forex_market_events", tipo topic, non-durable.
# Queues: exclusive + auto_delete para fan-out correto.

# Provedor de MQ. Usado por MQFactory.create_from_env() / create_async_from_env().
# Valores aceitos: RABBITMQ | RABBITMQ_ASYNC | REDIS
MQ_PROVIDER=RABBITMQ_ASYNC
# 🔏 Secret - Host do broker de mensageria (default: localhost).
MQ_HOST=localhost
# 🔏 Secret - Porta do broker de mensageria (default: 5672 para RabbitMQ).
MQ_PORT=5672
# 🔏 Secret -Usuário de autenticação no broker MQ (default: guest).
MQ_USER=guest
# 🔏 Secret — Senha de autenticação no broker MQ .
MQ_PASSWORD=guest
# Nome da queue padrão (fallback). A maioria dos componentes usa routing keys dinâmicas.
MQ_QUEUE=forex_trading_queue


# ======================================================================
# 11. TRADING EXECUTOR — RISCO  (RiskConfig)
# ======================================================================
# Proteção de capital: drawdown, exposição, margem, limites de posições.
# Valores alterados via hot update entram em efeito no próximo ciclo
# de avaliação do RiskManagerService._evaluate().

# Provedor de ordens usado pelo executor_trading.
# Valores aceitos: MT5 (real) | PAPER (simulação in-memory).
ORDER_PROVIDER=MT5

# Intervalo em segundos entre ciclos de avaliação de risco do RiskManagerService.
# Cada ciclo: account_info → drawdown → exposure → rules → alerts.
RISK_EVAL_INTERVAL=15.0

# Número de ciclos limpos consecutivos (sem alertas) necessários para
# auto-recovery de um estado EMERGENCY → publica EMERGENCY_CLEARED.
RISK_RECOVERY_CYCLES=3

# Drawdown máximo (%) que dispara EMERGENCY → fecha todas as posições e halt.
# Calculado como (peak_equity - current_equity) / peak_equity × 100.
RISK_MAX_DRAWDOWN_PCT=10.0

# Drawdown (%) que dispara WARNING (monitoramento, sem ação automática).
RISK_DRAWDOWN_WARN_PCT=5.0

# Perda diária máxima (%) que dispara CRITICAL (bloqueia novas ordens).
# Reset automático à meia-noite quando RISK_DAILY_RESET=true.
RISK_MAX_DAILY_PCT=5.0

# Número máximo de posições abertas simultâneas (global, todos os símbolos).
# Usado por RiskRules.MAX_OPEN_POSITIONS e RiskCalculator.MAX_OPEN_POSITIONS.
RISK_MAX_POS=10

# Exposição máxima (% do balanço) em nocional por símbolo individual.
# Dispara MAX_EXPOSURE_SYMBOL quando excedido.
RISK_MAX_EXPOSURE_PCT=5.0

# Nível de margem (%) que dispara WARNING de margem.
# margin_level = equity / margin × 100. Típico: 150% = alerta leve.
RISK_MARGIN_WARN=150.0

# Nível de margem (%) que dispara CRITICAL (margin call iminente).
# Típico: 100% = próximo do stop-out do broker.
RISK_MARGIN_CRIT=100.0

# Número máximo de perdas consecutivas antes de disparar WARNING.
# Rastreado via trading.orders (ORDER_RESULT) no RiskManagerService.
RISK_MAX_CONSEC_LOSSES=5

# Balanço inicial da conta para cálculo de drawdown pelo DrawdownMonitor.
# Se 0.0, usa o balanço reportado pela primeira chamada get_account_info().
INITIAL_BALANCE=0.0

# Se true, reseta o peak_equity do DrawdownMonitor à meia-noite (diário).
# Se false, peak_equity é acumulativo durante toda a sessão do serviço.
RISK_DAILY_RESET=true


# ======================================================================
# 12. PROVEDOR MT5  (ProviderConfig)
# ======================================================================

# Magic number para identificar ordens deste sistema no MetaTrader 5.
# Todas as ordens abertas pelo executor_trading recebem este magic number.
# Permite filtrar ordens do sistema vs ordens manuais no terminal.
MT5_MAGIC=20250311


# ======================================================================
# 13. POSITION SIZING & STOP LOSS  (SizerConfig)
# ======================================================================
# Dimensionamento de ordens e gestão de stop loss.
# Usado por PositionSizer e StopLossManager no executor_trading.

# Modo de cálculo de volume (lotes) das ordens.
# RISK_PCT: (balance × risk%) / (sl_pips × pip_value) — proporcional ao risco.
# FIXED_LOT: lote fixo independente do balanço.
# FIXED_RISK: valor monetário fixo / (sl_pips × pip_value).
SIZER_MODE=FIXED_LOT 

# Percentual do balanço arriscado por trade (usado quando SIZER_MODE=RISK_PCT).
# Ex: 0.01 = 1% do balanço por operação.
SIZER_RISK_PCT=0.01       

# Volume fixo em lotes (usado quando SIZER_MODE=FIXED_LOT).
SIZER_FIXED_LOT=0.10

# Volume máximo permitido em lotes (teto de segurança, qualquer modo).
SIZER_MAX_LOT=5.00

# Confiança mínima de sinal para que o executor aceite a ordem.
# Sinais com confidence < RISK_MIN_CONF são rejeitados pelo RiskCalculator.
RISK_MIN_CONF=0.55

# Número máximo de posições abertas por símbolo individual.
# Ex: 3 = no máximo 3 posições EURUSD ao mesmo tempo.
RISK_MAX_PER_SYM=3   

# Perda máxima diária como ratio do balanço (usado pelo executor RiskCalculator).
# Ex: 0.05 = 5% do balanço. ⚠️ Complementa RISK_MAX_DAILY_PCT (risk_manager).
RISK_MAX_LOSS_PCT=0.05 

# Modo de gestão de stop loss dinâmico pelo StopLossManager.
# TRAILING_PIPS: SL segue o preço a distância fixa em pips.
# BREAKEVEN: move SL para entry quando lucro atinge SL_BREAKEVEN_PIPS.
# BREAKEVEN_PLUS: move SL para entry + N pips (garante lucro mínimo).
# NONE: desativado (SL estático definido pelo sinal).
SL_MODE=TRAILING_PIPS

# Distância em pips do trailing stop (quando SL_MODE=TRAILING_PIPS).
# SL move apenas na direção favorável, nunca recua.
SL_TRAIL_PIPS=20

# Pips de lucro necessários para mover SL para breakeven (entry price).
# Quando SL_MODE=BREAKEVEN ou BREAKEVEN_PLUS.
SL_BREAKEVEN_PIPS=15


# ======================================================================
# 14. MONITORAMENTO E TIMINGS  (MonitorConfig)
# ======================================================================
# Cadência de polling e verificação de status dos componentes.

# Intervalo em segundos entre polls de posições abertas no broker (PositionManager).
# Detecta abertura/fechamento/modificação de posições e publica em trading.positions.
POLL_INTERVAL=5.0 

# Intervalo em segundos entre ciclos do TradeMonitor.
# Cada ciclo: StopLossManager.check_all() + ProfitMaximizer.check_all().
MONITOR_INTERVAL=10.0


# ======================================================================
# 15. PROFIT MAXIMIZER — TP DINÂMICO  (TPConfig)
# ======================================================================
# Gestão dinâmica de Take Profit pelo ProfitMaximizer (TradeMonitor).
# Roda sobre QUALQUER posição aberta, independente da estratégia de origem.

# Modo de operação do ProfitMaximizer.
# NONE: desativado (TP estático definido pelo sinal).
# TRAILING_TP: TP acompanha o preço a N × ATR de distância.
# INDICATOR_BASED: estende/aperta TP baseado em trend score (EMA/ADX/RSI/OBV).
# HYBRID: combina trailing + indicadores (recomendado para produção).
TP_MODE=HYBRID

# Trend score mínimo (0.0–1.0) para ESTENDER o TP (mais longe, deixar correr).
# Trend score calculado por TrendAssessment: EMA +0.25, ADX +0.25, RSI +0.15, OBV +0.10.
# Scores acima deste valor = tendência forte, favorece extensão do alvo.
TP_EXTEND_THRESHOLD=0.60

# Trend score abaixo do qual o TP é APERTADO (mais perto, proteger lucro).
# Scores abaixo deste valor = tendência fraca, favorece realização antecipada.
TP_TIGHTEN_THRESHOLD=0.30

# Multiplicador de ATR para extensão de TP.
# Novo TP = TP atual + (ATR × TP_EXTEND_ATR_MULT) na direção favorável.
TP_EXTEND_ATR_MULT=1.5

# Número máximo de extensões de TP permitidas por posição.
# Evita que posições fiquem abertas indefinidamente em tendências longas.
TP_MAX_EXTENSIONS=5

# Lucro mínimo em pips antes de permitir a primeira extensão de TP.
# Garante que a posição já está em lucro antes de mover o alvo.
TP_MIN_PROFIT_PIPS=10

# Multiplicador de ATR para trailing TP (modo TRAILING_TP e HYBRID).
# TP trail = preço atual - (ATR × TP_TRAIL_ATR_MULT) para BUY (inverso para SELL).
TP_TRAIL_ATR_MULT=2.0

# Distância mínima em pips para trailing TP (piso de segurança).
# Mesmo com ATR baixo, o trailing nunca fica mais próximo que este valor.
TP_TRAIL_MIN_PIPS=15

# Multiplicador de ATR para tightening (aperto) do TP quando tendência enfraquece.
# Novo TP = preço atual + (ATR × TP_TIGHTEN_ATR_MULT).
TP_TIGHTEN_ATR_MULT=1.0

# Se true, ativa profit lock (trava progressiva de lucro via ajuste de SL).
# Conforme o lucro cresce, SL é movido para garantir realização parcial.
TP_PROFIT_LOCK=true

# Pips de lucro necessários para ativar o primeiro nível de profit lock.
# Ex: 15 = só começa a travar lucro quando a posição tem ≥15 pips de profit.
TP_LOCK_START_PIPS=15

# Percentual do lucro atual que o SL trava.
# Ex: 0.50 = SL é movido para garantir 50% do lucro flutuante.
TP_LOCK_PCT=0.50

# Incremento em pips para ativar o próximo nível de profit lock.
# Ex: 10 = a cada 10 pips adicionais de lucro, um novo nível de lock é aplicado.
TP_LOCK_STEP_PIPS=10

# Movimento mínimo em pips para enviar modificação de TP ao broker.
# Evita chamadas desnecessárias a provider.modify_position() por variações ínfimas.
TP_MIN_MOVE_PIPS=3

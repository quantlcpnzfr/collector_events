# 6.1. CONTROLE DE CUSTOS LLM  (LlmCostGuard)
# ======================================================================
# Limites de orçamento e modelos para chamadas a LLMs.
# Evita gastos descontrolados em produção.

# Orçamento diário máximo em USD para todas as chamadas LLM combinadas.
LLM_DAILY_BUDGET_USD=3.00

# Modelo LLM padrão para operações rotineiras (custo baixo).

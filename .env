# ======================================================================
# 7. WORKERS DISTRIBUÍDOS  (WorkerConfig)
# ======================================================================
# Controla escalonamento horizontal de SessionWorkers gerenciados pelo BrokerOrchestrator.
# Workers são spawned como subprocessos e comunicam via MQ (worker.{id}.control).

# Threshold de carga (0.0–1.0) para spawn de novo worker. Quando a carga de todos os
# workers existentes excede este valor, BrokerOrchestrator cria um novo subprocess.
WORKER_SPAWN_THRESHOLD=0.8

# Timeout em segundos para considerar um worker como "dead" (sem heartbeat).
# Workers publicam heartbeats em worker.health a cada 30s.
WORKER_TIMEOUT_SECS=90

# Timeout em segundos para aguardar reply de um worker após envio de comando MQ.
WORKER_REPLY_TIMEOUT=30

# Número máximo de sessões de trading por worker. Quando atingido, novos
# SESSION_CREATE são roteados para outro worker ou um novo é spawned.
MAX_SESSIONS_PER_WORKER=10

# Número máximo de threads CPU no ThreadPoolExecutor (_CPU_EXECUTOR) para
# cálculos de indicadores/estratégias que rodam fora do event loop asyncio.
MAX_CPU_THREADS=4

# Timeout em segundos do BrokerClient (api_gateway → BrokerOrchestrator) para
# aguardar reply via temporary queue MQ (request-reply pattern).
BROKER_REPLY_TIMEOUT=15.0


# ======================================================================
# 8. RUNTIME DE SESSÕES / BROKER  (SessionRuntimeConfig)
# ======================================================================
# Configuração operacional do TradingSystemFacade, BrokerOrchestrator e sessões.

# Modo do TradingSystemFacade. Determina como sessões são criadas/gerenciadas.
# Valores aceitos: native (dev, mesmo processo) | broker (stateless MQ client) |
# distributed (BrokerOrchestrator + auto-scale de SessionWorkers).
FACADE_MODE=native

# Modo do BrokerOrchestrator (usado internamente pelo Facade distributed).
# Valores aceitos: native | distributed
BROKER_MODE=native

# Número máximo de candles no WARMUP enviado a cada sessão na inicialização.
# Mais candles = mais contexto histórico para indicadores e WalkForwardEngine.
WARMUP_LIMIT=500

# Número de workers no ThreadPoolExecutor dedicado a cálculos CPU-bound
# dentro de cada EventDrivenTradingSession.
SESSION_CPU_WORKERS=4

# Time-to-live em segundos de cada sessão no Redis (SessionRegistry).
# Expirado = sessão considerada morta para fins de recovery.
SESSION_TTL_SECS=3600

# Número máximo global de sessões simultâneas (todos os workers combinados).
MAX_SESSIONS=10

# ID único do worker (atribuído automaticamente pelo BrokerOrchestrator ou via CLI).
# Formato livre (ex: "worker-01", UUID). Vazio = auto-gerado.
WORKER_ID=

# Caminho para o arquivo JSON de catálogo de nomes (gen_names.json).
# Usado por NamesGenerator para gerar nomes únicos de sessão.
NAMES_FILE=

# Caminho para o arquivo JSON de configuração de sessões (sessions_config.json).
# Usado por launch_sessions.py para criar múltiplas sessões em batch.
SESSIONS_CONFIG=


